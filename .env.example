# ── Gateway ──
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8001
SSL_CERT=./certs/cert.pem
SSL_KEY=./certs/key.pem

# ── LLM (OpenAI-compatible endpoint) ──
VLLM_URL=http://localhost:8000/v1/chat/completions
VLLM_MODEL=gemma-4-12b

# ── Speech-to-Text ──
STT_MODEL=large-v3-turbo
STT_DEVICE=cuda
STT_BACKEND=transformers          # transformers (GPU) or faster_whisper (CPU)
# STT_COMPUTE=int8                # only for faster_whisper

# ── Text-to-Speech (Kokoro ONNX) ──
TTS_MODEL_DIR=./models/kokoro
TTS_VOICE=af_heart

# ── Voice Activity Detection ──
VAD_THRESHOLD=0.5
VAD_SILENCE_MS=400
VAD_MIN_SPEECH_MS=250

# ── Vision ──
ENABLE_VISION=1

# ── Conversation History ──
MAX_HISTORY_TURNS=10

# ── Agent Escalation (optional) ──
ENABLE_ESCALATION=1
AGENT_URL=http://localhost:8642/v1/chat/completions
AGENT_TOKEN=
AGENT_MODEL=gpt-4

# ── Person Recognition (optional, tool-based) ──
# Only used when the frontend declares the `identify_person` tool.
PERSON_URL=http://localhost:8765/v1/identify
PERSON_TOKEN=
PERSON_MIN_CONFIDENCE=0.55
